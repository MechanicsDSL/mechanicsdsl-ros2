<?xml version="1.0"?>
<?xml-model href="http://download.ros.org/schema/package_format3.xsd" schematypens="http://www.w3.org/2001/XMLSchema"?>
<package format="3">
  <name>mechanicsdsl_pendulum</name>
  <version>0.1.0</version>
  <description>
    Simple pendulum dynamics node generated by MechanicsDSL.
    Publishes state (theta, omega) and conserved energy at 250 Hz.
    Subscribes to initial condition and parameter reset topics.

    DSL specification:
      \system{pendulum}
      \parameter{m}{1.0}{kg}
      \parameter{l}{0.25}{m}
      \lagrangian{0.5*m*l^2*\dot{theta}^2 - m*g*l*(1-cos(theta))}
      \target{ros2}
  </description>

  <maintainer email="nomapa223@gmail.com">Noah Parsons</maintainer>
  <license>MIT</license>

  <url type="website">https://github.com/MechanicsDSL/mechanicsdsl-ros2</url>
  <url type="repository">https://github.com/MechanicsDSL/mechanicsdsl-ros2</url>

  <buildtool_depend>ament_cmake</buildtool_depend>

  <depend>rclcpp</depend>
  <depend>std_msgs</depend>
  <depend>geometry_msgs</depend>
  <depend>sensor_msgs</depend>

  <build_depend>rosidl_default_generators</build_depend>
  <exec_depend>rosidl_default_runtime</exec_depend>
  <member_of_group>rosidl_interface_packages</member_of_group>

  <test_depend>ament_lint_auto</test_depend>
  <test_depend>ament_lint_common</test_depend>
  <test_depend>ament_cmake_gtest</test_depend>

  <export>
    <build_type>ament_cmake</build_type>
  </export>
</package>
